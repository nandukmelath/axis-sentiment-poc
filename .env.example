# Copy to .env and fill in. The pipeline runs KEYLESS (VADER + Beam + heuristics) with no
# keys at all; add keys to unlock LLM depth and more sources.

# ---- database (default = local SQLite; set to Supabase/Postgres for prod) ----
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/db?sslmode=require

# ---- LLM provider (optional — pipeline degrades gracefully with no key) ----
LLM_PROVIDER=groq            # groq | openai | openrouter | deepseek | together | cerebras | ollama | gemini
GROQ_API_KEY=                # free + generous — console.groq.com/keys  (recommended)
LLM_MODEL=                   # optional classify-model override (else provider default: llama-3.3-70b-versatile)
BRIEF_MODEL=llama-3.1-8b-instant   # lighter model for the exec brief (bigger free daily budget)
# AUTO-FAILOVER when a free tier hits its limit -> flips to the next provider (each uses its own
# key; no-key providers skipped; ollama = keyless local + unlimited). Fixes "always hitting the limit".
LLM_FALLBACKS=cerebras,openrouter,together,gemini,ollama
CEREBRAS_API_KEY=            # free, very high limits — cloud.cerebras.ai
# BEST rate-limit fix — FreeLLMAPI (nandukmelath/freellmapi): ONE endpoint aggregating 16 free
# providers (~1.7B tokens/mo) with its own router + failover. Setup:
#   1. cd C:\Users\nandu\freellmapi && npm start -w server        (serves :3001)
#   2. open http://localhost:3001 -> add your free provider keys -> copy the unified key
#   3. set the 3 lines below AND  LLM_PROVIDER=freellmapi
# FREELLM_API_KEY=freellmapi-your-unified-key
# FREELLM_BASE_URL=http://localhost:3001/v1   # from WSL/Airflow use the Windows host IP: http://172.22.112.1:3001/v1
# FREELLM_MODEL=auto                          # let the router pick, or a specific id e.g. gemini-2.5-flash
# GEMINI_API_KEY=            # enables real cluster embeddings (else TF-IDF); Gemini can also be the classifier
# OPENAI_API_KEY= / OPENROUTER_API_KEY= / DEEPSEEK_API_KEY= / TOGETHER_API_KEY=
# OLLAMA_MODEL=llama3.1      # on-prem (LLM_PROVIDER=ollama) — RBI in-country residency
BATCH_SIZE=12
SLEEP_BETWEEN_BATCHES=4.5

# ---- pipeline behaviour ----
PII_MASK=1                   # mask card/PAN/Aadhaar/phone/OTP/email before any LLM call
CASCADE=1                    # VADER baseline for all, LLM depth only on negatives
BEAM_RUNNER=DirectRunner     # DataflowRunner for cloud-scale transform
SLA_RESPONSE_HOURS=24        # first-response SLA for the resolution fact

# ---- extra sources (all optional; news/play/appstore/mastodon/hackernews are keyless) ----
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=axis-sentiment-poc by u/yourname
YOUTUBE_API_KEY=
SCRAPEBADGER_API_KEY=        # X/Twitter via ScrapeBadger API (paid)
APPSTORE_APP_ID=             # optional; auto-resolved from APPSTORE_SEARCH if blank

# ---- Airflow worker (see AIRFLOW.md) ----
# AXIS_PROJECT_DIR=/mnt/c/Users/nandu/axis-sentiment-poc
# AXIS_PYTHON=/home/you/axis-venv/bin/python   # venv with project deps (separate from Airflow's venv)
# AXIS_SCHEDULE=*/30 * * * *                    # enable the recurring schedule
